name: Daily Cartoon Video Generation

on:
  schedule:
    # Runs every day at 9:00 AM UTC
    - cron: '0 9 * * *'
  workflow_dispatch:  # Allows manual trigger

jobs:
  generate-video:
    runs-on: ubuntu-latest
    
    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.10'

      - name: Install FFmpeg
        run: sudo apt-get update && sudo apt-get install -y ffmpeg

      - name: Install Python dependencies
        run: pip install openai requests edge-tts

      - name: Run video generation
        env:
          DEEPSEEK_API_KEY: ${{ secrets.DEEPSEEK_API_KEY }}
          HF_TOKEN: ${{ secrets.HF_TOKEN }}
          STORY_LANG: "hindi"
          STORY_DURATION: "10"
        run: python cheapest_pipeline.py

      - name: Upload video as artifact
        uses: actions/upload-artifact@v4
        with:
          name: generated-video-$(date +%Y%m%d)
          path: output/final_video.mp4
          retention-days: 7
